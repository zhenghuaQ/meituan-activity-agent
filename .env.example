# ============================================================
# AI出行决策 Agent — 环境变量配置模板
# 复制为 .env 并填入实际值
# ============================================================

# --- 运行环境与日志 ---
# APP_ENV: dev | demo | production（默认 dev）
APP_ENV=dev
# 日志级别: trace|debug|info|warn|error（默认 info）
LOG_LEVEL=info
# 日志格式: 设为 false 输出 JSON 结构化日志（默认彩色易读）
# LOG_PRETTY=true

# --- 特性开关（不填则按"密钥是否存在"自动决定；on/off 可强制覆盖）---
# FEATURE_LLM=on          # LLM 意图解析
# FEATURE_AMAP=on         # 高德真实数据
# FEATURE_CACHE=on        # 结果缓存
# FEATURE_RATE_LIMIT=on   # 限流
# FEATURE_DEGRADE=on      # 降级策略

# --- LLM 配置（OpenAI 兼容接口）---
# 支持: DeepSeek / 通义千问(DashScope) / 智谱GLM / 硅基流动 等
# 不填则自动降级为 Mock（关键词匹配）

# API 地址（各家不同，见下方示例）
LLM_BASE_URL=https://api.deepseek.com/v1

# API Key
LLM_API_KEY=sk-your-key-here

# 模型名称
LLM_MODEL=deepseek-chat

# --- 高德地图 API 配置 ---
# 不填则自动降级为 Mock 通勤计算

# 高德 Web API Key（需从 https://lbs.amap.com 申请）
AMAP_API_KEY=your-amap-key-here


# ─── 各厂商配置示例 ──────────────────────────────────
# DeepSeek:
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#
# 通义千问 (DashScope):
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen-plus
#
# 智谱 GLM:
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   LLM_MODEL=glm-4-flash
#
# 硅基流动 (SiliconFlow):
#   LLM_BASE_URL=https://api.siliconflow.cn/v1
#   LLM_MODEL=deepseek-ai/DeepSeek-V3